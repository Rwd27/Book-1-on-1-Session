<td>{{session_slot}}</td>
</tr>

<tr>
<td><strong>Mode</strong></td>
<td>{{session_mode}}</td>
</tr>

<tr>
<td><strong>Course</strong></td>
<td>{{course}}</td>
</tr>

<tr>
<td><strong>Webinar Attended</strong></td>
<td>{{webinar_name}}</td>
</tr>

</table>

</td>
</tr>

</table>

</td>
</tr>

<!-- BENEFITS -->

<tr>
<td style="padding:0 40px 30px 40px;">

<table width="100%" cellpadding="0" cellspacing="0" style="background:#fff8dd;border:1px solid #f5c518;border-radius:18px;">

<tr>
<td style="padding:25px;">

<h3 style="margin-top:0;color:#7a5d00;">
