<title>IIC Lakshya Scholarship Code</title>
</head>

<body style="margin:0;padding:0;background:#eef4ff;font-family:Arial,sans-serif;">

<table width="100%" cellpadding="0" cellspacing="0" style="padding:30px 10px;">
<tr>
<td align="center">

<table width="700" cellpadding="0" cellspacing="0" style="max-width:700px;background:#ffffff;border-radius:24px;overflow:hidden;box-shadow:0 10px 40px rgba(0,0,0,0.12);">

<!-- HEADER -->

<tr>
<td style="background:linear-gradient(135deg,#081d52,#1a4bb5);padding:40px;text-align:center;">

        <div style="margin: -35px 0 1rem -15px; width: 100%; max-width: 260px; height: 75px; overflow: hidden; display: flex; align-items: center; justify-content: flex-start;">
            <img src="https://drive.google.com/uc?id=1m8a_QZcopm14DEzmBIqM9Th9A4Eea_0M&export=download" 
                 alt="Logo" 
                 style="width: 100%; height: auto; margin-top: 5px; object-fit: contain; display: block;">
        </div>

<h1 style="color:#ffffff;margin:10px 0 0 0;font-size:34px;">
Scholarship Passport
</h1>

<p style="color:#dbeafe;margin-top:10px;">
Faculty Connect Program 2026
</p>

</td>
</tr>

<!-- SUCCESS -->

<tr>
<td style="padding:40px;">

<h2 style="color:#0b2563;margin-top:0;">
🎉 Congratulations {{student_name}}
</h2>

<p style="font-size:16px;color:#555;line-height:1.8;">
Your registration has been successfully confirmed.
You have secured your Faculty Connect Session and Scholarship Passport.
</p>

</td>
</tr>

<!-- SCHOLARSHIP CODE -->

<tr>
<td style="padding:0 40px 20px 40px;">

<table width="100%" cellpadding="0" cellspacing="0" style="background:linear-gradient(135deg,#111827,#0b2563);border-radius:20px;overflow:hidden;">

<tr>
<td style="padding:30px;text-align:center;">

<div style="font-size:13px;color:#f5c518;font-weight:bold;letter-spacing:3px;">
🏅 YOUR SCHOLARSHIP CODE
</div>

<div style="font-size:42px;color:#ffffff;font-weight:bold;letter-spacing:4px;margin-top:15px;">
{{scholarship_code}}
</div>

<div style="margin-top:15px;color:#dbeafe;font-size:14px;">
Share this code during enrollment to unlock scholarship benefits.
</div>

</td>
</tr>

</table>

</td>
</tr>

<!-- SESSION CARD -->

